# Supabase Credentials
# Copy this file to .env and fill in your details from your Supabase Dashboard

# Your Supabase Project URL (e.g., https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
# Found in Project Settings -> API -> Project URL
VITE_SUPABASE_URL="your-supabase-url-here"

# Your Supabase Anon Key 
# Found in Project Settings -> API -> Project API Keys
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# NOTE: For OAuth (Google, GitHub, Apple) to work locally, 
# you MUST enable these providers in your Supabase Dashboard under 
# Authentication -> Providers. No additional environment variables 
# are required here for OAuth; Supabase handles the provider secrets securely.
